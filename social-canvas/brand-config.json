  "style": "monochromatic-technical",
  "branding_element": "logo",
  "branding_note": "Use Fractal AI logo (tree_with_text_transparent) in bottom-left of every slide. NEVER use a text handle like @username. Pair with the website note (right side of bottom bar) — never a slide number.",
