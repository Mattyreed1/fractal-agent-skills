  },
  "color_rules": "Pick ONE accent color per piece. That color carries ONE meaning throughout. Default is monochromatic (no accent). See references/fractal-ai-visual-style.md for full rules.",
  "fonts": {
    "loading_method": "google_fonts_import",
    "import_url": "https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800&family=Geist+Mono:wght@400;500;700;800&family=Silkscreen:wght@400;700&display=swap",
    "sans": "Geist",
    "mono": "Geist Mono",
    "eyebrow": "Silkscreen"
  },
  "logos": {
    "tree_with_text_transparent": "brand-assets/fractal-ai-logo-tree-text-transparent-bg.png",
    "tree_with_text": "brand-assets/fractal-ai-logo-tree-text.png",
    "tree_lg": "brand-assets/lg_fractal-ai-logo-tree.png",
    "tree_lg_transparent": "brand-assets/lg_fractal-ai-logo-tree-transparent.png",
    "tree_md": "brand-assets/md_fractal-ai-logo-tree.png",
    "tree_md_transparent": "brand-assets/md_fractal-ai-logo-tree-transparent-bg.png",
    "tree_xs": "brand-assets/xs_fractal-ai-logo-tree.png"
