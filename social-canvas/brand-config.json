    "border": "#1c1c22",
    "text": "#fafafa",
    "text_muted": "#71717a",
    "text_dim": "#3f3f46"
  },
  "accent_palette": {
    "teal": "#00c6a2",
    "emerald": "#10b981",
    "blue": "#3b82f6",
    "amber": "#f59e0b",
    "pink": "#ec4899"
  },
  "accent_gradient": "linear-gradient(135deg, #00c6a2, #0077ff)",
